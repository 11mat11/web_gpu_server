{
  "name": "webgpu-thesis-server",
  "version": "0.2.0",
  "description": "WebGPU performance analysis in Node.js - REST API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx src/benchmarks/runner.ts",
    "render:bench": "tsx src/benchmarks/render-scene.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "jpeg-js": "^0.4.4",
    "node-addon-api": "^8.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "webgpu": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@webgpu/types": "^0.1.69",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
