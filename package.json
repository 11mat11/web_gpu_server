{
	"name": "webgpu-thesis-server",
	"version": "0.2.0",
	"description": "WebGPU performance analysis in Node.js - REST API server",
	"main": "dist/index.js",
	"scripts": {
		"dev": "NODE_OPTIONS=\"--max-old-space-size=16384 --expose-gc\" tsx watch src/index.ts",
		"build": "tsc && copyfiles -u 1 \"src/**/*.wgsl\" \"src/**/*.bin\" dist/",
		"start": "NODE_OPTIONS=\"--max-old-space-size=16384 --expose-gc\" node dist/index.js",
		"lint": "eslint src --ext .ts",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"bench": "tsx src/benchmarks/runner.ts",
		"render:bench": "tsx src/benchmarks/render-scene.ts",
		"lint:fix": "eslint \"src/**/*.ts\" --fix"
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/multipart": "^9.4.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^5.2.5",
		"@fastify/websocket": "^11.2.0",
		"dotenv": "^16.6.1",
		"fastify": "^5.8.5",
		"jpeg-js": "^0.4.4",
		"node-addon-api": "^8.7.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"webgpu": "^0.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.15.0",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"@webgpu/types": "^0.1.69",
		"copyfiles": "^2.4.1",
		"eslint": "^10.3.0",
		"prettier": "^3.8.3",
		"prettier-plugin-wgsl": "^0.1.10",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.2",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"type": "module"
}